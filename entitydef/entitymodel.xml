<entitymodel xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://ofbiz.apache.org/dtds/entitymodel.xsd">
    <!-- ========================================================= -->
    <!-- ======================== Defaults ======================= -->
    <!-- ========================================================= -->
    <title>Entity of Sphinx Component</title>
    <description>None</description>
    <copyright></copyright>
    <version></version>

  <entity entity-name="employee" package-name="org.apache.ofbiz.Employee"  title="Employee Demo Entity">
    <field name="EmployeeId" type="id"></field>
    <field name="EmployeeName" type="name"></field>
    <field name="EmployeePhone" type="numeric"></field>
    <field name="DeptName" type="short-varchar"></field>
    <prim-key field="EmployeeId"/>
    </entity>

    
     <!-- This entity holds exams & their information -->
	<entity entity-name="ExamMaster" package-name="in.vastpro.sphinx">
		<field name="examId" type="id"></field>
		<field name="examName" type="id"></field>		
		<field name="description" type="description"></field>
		<field name="noOfQuestions" type="numeric" not-null="true"></field>
		<field name="duration" type="numeric" not-null="true"></field>
		<field name="passPercentage" type="numeric" not-null="true"/>
		<field name="questionsRandomized" type="numeric"></field>
		<field name="answersMust" type="numeric"></field>
		<field name="allowNegativeMarks" type="numeric"/>
		<field name="examSetupProper" type="numeric"></field>
		<field name="negativeMarkValue" type="currency-amount"></field>
		<field name="fromDate" type="date-time"></field>
		<field name="thruDate" type="date-time"></field>
		<!--field to store the adminId who created this exam -->
		<field name="createdByUserLogin" type="id-vlong"></field>
		<!--field to store the adminId who last modified this exam -->
		 <field name="lastModifiedByUserLogin" type="id-vlong"></field>
		<prim-key field="examId" />
    </entity>   
    
    
   <entity entity-name="QuestionMaster"  package-name="">
		<field name="questionId" type="name" />
		<field name="questionDetail" type="very-long" />
		<field name="optionA" type="very-long" />
		<field name="optionB" type="very-long" />
		<field name="optionC" type="very-long" />
		<field name="optionD" type="very-long" />
		<field name="answer" type="short-varchar" />
		<field name="numAnswers" type="numeric" />
		<field name="questionTypeId" type="short-varchar" />
		<field name="difficultyLevel" type="numeric" />
		<field name="answerValue" type="fixed-point" />
		<field name="topicId" type="id" />
		<field name="negativeMarkValue" type="fixed-point" />
		<prim-key field="questionId" />
		<relation type="one" rel-entity-name="TopicMaster">
			<key-map field-name="topicId" />
		</relation>
		<relation type="one" rel-entity-name="Enumeration">
			<key-map field-name="questionTypeId" rel-field-name="enumId" />
		</relation>
	</entity>
    
         <entity entity-name="QuestionBankMasterB" package-name="in.vastpro.sphinx">
		<field name="examId" type="id"></field>
		<field name="qId" type="numeric"></field>
		<field name="topicId" type="numeric" not-null="true"/>
		<field name="questionDetail" type="very-long" not-null="true"></field>
		<field name="optiona" type="very-long" not-null="true"></field>
		<field name="optionb" type="very-long" not-null="true"/>
		<field name="optionc" type="very-long" not-null="true"></field>
		<field name="optiond" type="very-long" not-null="true"></field>
		<field name="optione" type="very-long" not-null="true"></field>
		<field name="answer" type="id" not-null="true"></field>
		<field name="numAnswers" type="numeric" not-null="true"/>
		<field name="questiontype" type="numeric" not-null="true"></field>
		<field name="difficultyLevel" type="numeric"></field>
		<field name="answerValue" type="currency-amount"/>
		<field name="negativeMarkValue" type="currency-amount"></field>			
		<prim-key field="examId" />
		<prim-key field="qId" />
		<relation rel-entity-name="ExamMaster" fk-name="QUESTION_BANK_B_FK" type="many">
			<key-map field-name="examId" rel-field-name="examId" />
		</relation>			
    </entity>
    
     <entity entity-name="QuestionBankMaster" package-name="in.vastpro.sphinx">
		<field name="examId" type="id-ne"></field>
		<field name="qId" type="numeric"></field>
		<field name="topicId" type="numeric" not-null="true"/>
		<field name="questionDetail" type="very-long" not-null="true"></field>
		<field name="optiona" type="very-long" not-null="true"></field>
		<field name="optionb" type="very-long" not-null="true"/>
		<field name="optionc" type="very-long" not-null="true"></field>
		<field name="optiond" type="very-long" not-null="true"></field>
		<field name="optione" type="very-long" not-null="true"></field>
		<field name="answer" type="id-ne" not-null="true"></field>
		<field name="numAnswers" type="numeric" not-null="true"/>
		<field name="questionType" type="numeric" not-null="true"></field>
		<field name="difficultyLevel" type="numeric"></field>
		<field name="answerValue" type="currency-amount"/>
		<field name="negativeMarkValue" type="currency-amount"></field>		
		<prim-key field="examId" />
		<prim-key field="qId" />
		<relation rel-entity-name="ExamMaster" fk-name="QUESTION_BANK_FK" type="many">
			<key-map field-name="examId" rel-field-name="examId" />
		</relation>			
    </entity>
    <entity entity-name="TopicMaster" package-name="">
		<field name="topicId" type="name"></field>
		
		<field name="topicName" type="name"  not-null="true" />
		
		
		<prim-key field="topicId" />
	<index name="TOPIC_NAME_UNIQUE" unique="true">
        <index-field name="topicName"/>
    </index>
			
    </entity>
    
    
    
  <entity entity-name="ExamTopicDetails" package-name="in.vastpro.sphinx">
 
    <!-- Foreign Keys -->
    <field name="examId" type="id"/>
    <field name="topicId" type="name"/>
 
    <!-- Additional Fields -->
    <field name="percentage" type="numeric" not-null="false"/>
    <field name="startingQid" type="numeric" not-null="false"/>
    <field name="endingQid" type="numeric" not-null="false"/>
    <field name="questionsPerExam" type="numeric" not-null="false"/>
    <field name="topicPassPercentage" type="floating-point" not-null="true"/>
 
    <!-- Composite Primary Key -->
    <prim-key field="examId"/>
    <prim-key field="topicId"/>
 
    <!-- Relation with ExamMaster -->
    <relation rel-entity-name="ExamMaster"
              fk-name="EXAM_TOPIC_FK"
              type="one">
        <key-map field-name="examId" rel-field-name="examId"/>
    </relation>
 
    <!-- Relation with TopicMaster -->
    <relation rel-entity-name="TopicMaster"
              fk-name="EXAM_TOPIC_TOPIC_FK"
              type="one">
        <key-map field-name="topicId" rel-field-name="topicId"/>
    </relation>
 
</entity>

    
    
    <entity entity-name="PartyExamRelationship" package-name="in.vastpro.sphinx">
		<field name="partyId" type="id"></field>
		<field name="examId" type="id"></field>
		<field name="allowedAttempts" type="numeric" not-null="true"/>
		<field name="noOfAttempts" type="numeric" not-null="true"></field>
		<field name="lastPerformanceDate" type="date-time"></field>
		<field name="certificatePrinted" type="numeric"/>
		<field name="timeoutDays" type="numeric" not-null="true"></field>
		<field name="passwordChangesAuto" type="numeric"></field>
		<field name="canSplitExams" type="numeric"/>
		<field name="canSeeDetailedResults" type="numeric"></field>
		<field name="maxSplitAttempts" type="numeric"></field>
		<!-- A party can take th exam only within these stipulated dates -->
		<field name="fromDate" type="date-time"></field>
		<field name="thruDate" type="date-time"></field>
		<prim-key field="partyId" />
		<prim-key field="examId" />
		<relation rel-entity-name="Party" fk-name="USER_EXAM_UID_FK" type="many">
			<key-map field-name="partyId" rel-field-name="partyId" />
		</relation>	
		<relation rel-entity-name="ExamMaster" fk-name="USER_EXAM_EID_FK" type="many">
			<key-map field-name="examId" rel-field-name="examid" />
		</relation>			
    </entity>

	
	 <entity entity-name="QuestionBankMasterB" package-name="">
    <field name="examId"            type="id"/>
    <field name="qId"               type="name"/>
    <field name="topicId"           type="name"       not-null="true"/>
    <field name="questionDetail"    type="very-long"  not-null="true"/>
    <field name="optionA"           type="very-long"/>  
    <field name="optionB"           type="very-long"/>  
    <field name="optionC"           type="very-long"/>   
    <field name="optionD"           type="very-long"/>  
    <field name="answer"            type="short-varchar" not-null="true"/>
    <field name="numAnswers"        type="numeric"/>
    <field name="questionTypeId"    type="short-varchar"/>
    <field name="difficultyLevel"   type="numeric"/>
    <field name="answerValue"       type="fixed-point"/>
    <field name="negativeMarkValue" type="fixed-point"/>
    <prim-key field="examId"/>
    <prim-key field="qId"/>
    <relation rel-entity-name="ExamMaster" fk-name="QUESTION_BANK_B_FK" type="many">
        <key-map field-name="examId" rel-field-name="examId"/>
    </relation>
</entity>

 <entity entity-name="AssignExamTempoary" package-name="in.vastpro.sphinx">
    
    <field name="examId" type="id"/>
    <field name="partyId" type="id"/>
     
    <field name="noOfAttempts" type="id" not-null="true"/>
    <field name="timeoutDays" type="id" not-null="true"/>
    <field name="allowedAttempts" type="id" not-null="true"/>
    <field name="userLoginId" type="id" not-null="true"></field>
    
    <prim-key field="examId"/>
    <prim-key field="partyId"/>

    <relation rel-entity-name="ExamMaster" type="one" fk-name="AUTO_EXAM_FK">
        <key-map field-name="examId" rel-field-name="examId"/>
    </relation>

</entity>

<view-entity entity-name="ExamPartyUserLoginView" package-name="in.vastpro.sphinx">

    <!-- 1. member entities -->
    <member-entity entity-alias="PER" entity-name="PartyExamRelationship"/>
    <member-entity entity-alias="UL" entity-name="UserLogin"/>
    <member-entity entity-alias="EM" entity-name="ExamMaster"/>

    <!-- 2. joins -->
    <!-- PER -> UL -->
    <view-link entity-alias="PER" rel-entity-alias="UL" rel-optional="true">
        <key-map field-name="partyId" rel-field-name="partyId"/>
    </view-link>

    <!-- PER -> EM -->
    <view-link entity-alias="PER" rel-entity-alias="EM" rel-optional="true">
        <key-map field-name="examId" rel-field-name="examId"/>
    </view-link>

    <!-- 3. alias -->
    <alias entity-alias="PER" name="partyId" field="partyId"/>
    <alias entity-alias="UL" name="userLoginId" field="userLoginId"/>
    <alias entity-alias="EM" name="examId" field="examId"/>
    <alias entity-alias="EM" name="examName" field="examName"/>
    
    

</view-entity>

<entity entity-name="AdminPartyExamRel" package-name="in.vastpro.sphinx">
		<field name="partyId" type="id"></field>
		<field name="examId" type="id"></field>
<!--Date threshold to control from when to when an Admin can manage the exam -->		
		<field name="fromDate" type="date-time"></field>
		<field name="thruDate" type="date-time"></field>
		<prim-key field="partyId" />
		<prim-key field="examId" />
		<relation rel-entity-name="Party" fk-name="USER_EXAM_UID_FK" type="many">
			<key-map field-name="partyId" rel-field-name="partyId" />
		</relation>	
		<relation rel-entity-name="ExamMaster" fk-name="USER_EXAM_EID_FK" type="many">
			<key-map field-name="examId" rel-field-name="examid" />
		</relation>			
    </entity>
 

</entitymodel>

